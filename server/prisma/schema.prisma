// Prisma Schema - 自动从 MySQL 生成
// 生成命令: npx prisma db pull
// 客户端:    npx prisma generate

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  customer
  vip
  staff
  admin
}

enum Status {
  active
  suspended
  pending
}

enum Direction {
  Unidirectional
  Bidirectional
}

enum InquiryStatus {
  new
  processing
  quoted
  won
  lost
  closed
}

enum OrderStatus {
  pending
  confirmed
  paid
  producing
  shipped
  delivered
  cancelled
  refunded
}

enum Language {
  en
  zh
  pt_BR @map("pt-BR")
  ru
}

enum Currency {
  USD
  CNY
  BRL
  RUB
  EUR
}

model User {
  id                  Int       @id @default(autoincrement())
  email               String    @unique @db.VarChar(120)
  passwordHash        String    @map("password_hash") @db.VarChar(255)
  fullName            String    @map("full_name") @db.VarChar(80)
  avatar              String?   @db.VarChar(255)
  phone               String?   @db.VarChar(40)
  whatsapp            String?   @db.VarChar(40)
  role                Role      @default(customer)
  companyId           Int?      @map("company_id")
  preferredLanguage   Language  @default(en) @map("preferred_language")
  preferredCurrency   Currency  @default(USD) @map("preferred_currency")
  emailVerifiedAt     DateTime? @map("email_verified_at")
  lastLoginAt         DateTime? @map("last_login_at")
  status              Status    @default(active)
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  company             Company?      @relation(fields: [companyId], references: [id])
  addresses           Address[]
  inquiries           Inquiry[]
  orders              Order[]
  favorites           Favorite[]
  compareList         CompareList[]
  reviews             Review[]

  @@index([companyId])
  @@index([role])
  @@map("users")
}

model Company {
  id              Int       @id @default(autoincrement())
  name            String    @db.VarChar(150)
  nameEn          String?   @map("name_en") @db.VarChar(200)
  businessLicense String?   @map("business_license") @db.VarChar(80)
  taxId           String?   @map("tax_id") @db.VarChar(60)
  country         String    @db.VarChar(60)
  state           String?   @db.VarChar(60)
  city            String?   @db.VarChar(60)
  address         String?   @db.VarChar(255)
  postalCode      String?   @map("postal_code") @db.VarChar(20)
  industry        String?   @db.VarChar(80)
  website         String?   @db.VarChar(200)
  contactEmail    String?   @map("contact_email") @db.VarChar(120)
  contactPhone    String?   @map("contact_phone") @db.VarChar(40)
  verified        Boolean   @default(false)
  creditLimit     Decimal   @default(0) @map("credit_limit") @db.Decimal(12, 2)
  vipLevel        Int       @default(0) @map("vip_level") @db.UnsignedTinyInt
  createdAt       DateTime  @default(now()) @map("created_at")

  users           User[]

  @@index([name])
  @@map("companies")
}

model Address {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  label        String?  @db.VarChar(50)
  contactName  String   @map("contact_name") @db.VarChar(80)
  contactPhone String   @map("contact_phone") @db.VarChar(40)
  country      String   @db.VarChar(60)
  state        String?  @db.VarChar(60)
  city         String   @db.VarChar(60)
  addressLine1 String   @map("address_line1") @db.VarChar(200)
  addressLine2 String?  @map("address_line2") @db.VarChar(200)
  postalCode   String?  @map("postal_code") @db.VarChar(20)
  isDefault    Boolean  @default(false) @map("is_default")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("addresses")
}

model Category {
  id         Int      @id @default(autoincrement())
  parentId   Int?     @map("parent_id")
  slug       String   @unique @db.VarChar(80)
  icon       String?  @db.VarChar(50)
  sortOrder  Int      @default(0) @map("sort_order")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")

  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  products    Product[]
  translations CategoryTranslation[]

  @@index([parentId])
  @@map("categories")
}

model CategoryTranslation {
  id          Int      @id @default(autoincrement())
  categoryId  Int      @map("category_id")
  language    Language
  name        String   @db.VarChar(120)
  description String?  @db.VarChar(500)

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, language])
  @@map("category_translations")
}

model Product {
  id             Int      @id @default(autoincrement())
  sku            String   @unique @db.VarChar(80)
  model          String   @db.VarChar(80)
  slug           String   @unique @db.VarChar(120)
  categoryId     Int      @map("category_id")
  packageType    String   @map("package_type") @db.VarChar(40)
  direction      Direction
  vrwm           String   @db.VarChar(40)
  vrwmMin        Decimal  @map("vrwm_min") @db.Decimal(5, 2)
  vrwmMax        Decimal  @map("vrwm_max") @db.Decimal(5, 2)
  cjValue        Decimal  @map("cj_value") @db.Decimal(8, 3)
  cjDisplay      String   @map("cj_display") @db.VarChar(20)
  ippmValue      Decimal  @map("ippm_value") @db.Decimal(8, 3)
  ippmDisplay    String   @map("ippm_display") @db.VarChar(20)
  packageQty     String   @map("package_qty") @db.VarChar(60)
  moq            Int      @default(1000)
  leadTimeDays   Int      @default(14) @map("lead_time_days")
  stockQty       Int      @default(0) @map("stock_qty")
  priceUsd       Decimal  @default(0) @map("price_usd") @db.Decimal(10, 4)
  datasheetUrl   String?  @map("datasheet_url") @db.VarChar(255)
  rohsCompliant  Boolean  @default(true) @map("rohs_compliant")
  reachCompliant Boolean  @default(true) @map("reach_compliant")
  isActive       Boolean  @default(true) @map("is_active")
  isFeatured     Boolean  @default(false) @map("is_featured")
  viewCount      Int      @default(0) @map("view_count")
  inquiryCount   Int      @default(0) @map("inquiry_count")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  category      Category              @relation(fields: [categoryId], references: [id])
  translations  ProductTranslation[]
  images        ProductImage[]
  priceBreaks   ProductPriceBreak[]
  favorites     Favorite[]
  compareItems  CompareList[]
  reviews       Review[]
  orderItems    OrderItem[]
  relatedFrom   ProductRelated[]      @relation("RelatedFrom")
  relatedTo     ProductRelated[]      @relation("RelatedTo")

  @@index([model])
  @@index([packageType])
  @@index([categoryId])
  @@index([vrwmMin, vrwmMax])
  @@index([cjValue])
  @@index([ippmValue])
  @@map("products")
}

model ProductTranslation {
  id           Int      @id @default(autoincrement())
  productId    Int      @map("product_id")
  language     Language
  name         String   @db.VarChar(150)
  shortDesc    String?  @map("short_desc") @db.VarChar(500)
  longDesc     String?  @db.Text
  applications String?  @db.Text
  keywords     String?  @db.VarChar(255)
  metaTitle    String?  @map("meta_title") @db.VarChar(150)
  metaDesc     String?  @map("meta_desc") @db.VarChar(255)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, language])
  @@map("product_translations")
}

model ProductImage {
  id         Int      @id @default(autoincrement())
  productId  Int      @map("product_id")
  imageType  String   @map("image_type") @db.VarChar(20)
  url        String   @db.VarChar(500)
  altText    String?  @map("alt_text") @db.VarChar(200)
  sortOrder  Int      @default(0) @map("sort_order")
  isPrimary  Boolean  @default(false) @map("is_primary")
  createdAt  DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

model ProductPriceBreak {
  id        Int      @id @default(autoincrement())
  productId Int      @map("product_id")
  minQty    Int      @map("min_qty")
  maxQty    Int?     @map("max_qty")
  priceUsd  Decimal  @map("price_usd") @db.Decimal(10, 4)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, minQty])
  @@map("product_price_breaks")
}

model ProductRelated {
  id           Int      @id @default(autoincrement())
  productId    Int      @map("product_id")
  relatedId    Int      @map("related_id")
  relationType String   @map("relation_type") @db.VarChar(20)

  product   Product @relation("RelatedFrom", fields: [productId], references: [id], onDelete: Cascade)
  related   Product @relation("RelatedTo",   fields: [relatedId], references: [id], onDelete: Cascade)

  @@unique([productId, relatedId, relationType])
  @@map("product_related")
}

model Inquiry {
  id                Int           @id @default(autoincrement())
  inquiryNo         String        @unique @map("inquiry_no") @db.VarChar(40)
  userId            Int?          @map("user_id")
  companyName       String        @map("company_name") @db.VarChar(150)
  contactName       String        @map("contact_name") @db.VarChar(80)
  contactEmail      String        @map("contact_email") @db.VarChar(120)
  contactPhone      String?       @map("contact_phone") @db.VarChar(40)
  whatsapp          String?       @db.VarChar(40)
  country           String?       @db.VarChar(60)
  industry          String?       @db.VarChar(80)
  application       String?       @db.VarChar(255)
  totalQty          Int           @default(0) @map("total_qty")
  targetPrice       Decimal?      @map("target_price") @db.Decimal(10, 4)
  currency          Currency      @default(USD)
  incoterm          String        @default("FOB") @db.VarChar(10)
  status            InquiryStatus @default(new)
  assignedTo        Int?          @map("assigned_to")
  quoteAmount       Decimal?      @map("quote_amount") @db.Decimal(12, 2)
  quoteCurrency     Currency?     @map("quote_currency")
  quoteValidUntil   DateTime?     @map("quote_valid_until") @db.Date
  notes             String?       @db.Text
  internalNotes     String?       @map("internal_notes") @db.Text
  source            String        @default("web") @db.VarChar(20)
  preferredLanguage Language      @default(en) @map("preferred_language")
  ipAddress         String?       @map("ip_address") @db.VarChar(45)
  userAgent         String?       @map("user_agent") @db.VarChar(500)
  bomFileUrl        String?       @map("bom_file_url") @db.VarChar(500)
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  user     User?            @relation(fields: [userId], references: [id])
  items    InquiryItem[]
  messages InquiryMessage[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("inquiries")
}

model InquiryItem {
  id           Int      @id @default(autoincrement())
  inquiryId    Int      @map("inquiry_id")
  productId    Int?     @map("product_id")
  model        String   @db.VarChar(80)
  brand        String?  @db.VarChar(60)
  packageType  String?  @map("package_type") @db.VarChar(40)
  qty          Int
  targetPrice  Decimal? @map("target_price") @db.Decimal(10, 4)
  remark       String?  @db.VarChar(255)

  inquiry Inquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)

  @@index([inquiryId])
  @@map("inquiry_items")
}

model InquiryMessage {
  id            Int      @id @default(autoincrement())
  inquiryId     Int      @map("inquiry_id")
  senderType    String   @map("sender_type") @db.VarChar(20)
  senderId      Int?     @map("sender_id")
  content       String   @db.Text
  attachmentUrl String?  @map("attachment_url") @db.VarChar(500)
  createdAt     DateTime @default(now()) @map("created_at")

  inquiry Inquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)

  @@index([inquiryId])
  @@map("inquiry_messages")
}

model Order {
  id                Int         @id @default(autoincrement())
  orderNo           String      @unique @map("order_no") @db.VarChar(40)
  userId            Int         @map("user_id")
  inquiryId         Int?        @map("inquiry_id")
  status            OrderStatus @default(pending)
  subtotal          Decimal     @db.Decimal(12, 2)
  shippingFee       Decimal     @default(0) @map("shipping_fee") @db.Decimal(10, 2)
  tax               Decimal     @default(0) @db.Decimal(10, 2)
  discount          Decimal     @default(0) @db.Decimal(10, 2)
  total             Decimal     @db.Decimal(12, 2)
  currency          Currency    @default(USD)
  paymentMethod     String?     @map("payment_method") @db.VarChar(30)
  paymentStatus     String      @default("unpaid") @map("payment_status") @db.VarChar(20)
  incoterm          String      @default("FOB") @db.VarChar(10)
  shippingAddressId Int?        @map("shipping_address_id")
  trackingNo        String?     @map("tracking_no") @db.VarChar(100)
  shippingCarrier   String?     @map("shipping_carrier") @db.VarChar(60)
  notes             String?     @db.Text
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  user  User        @relation(fields: [userId], references: [id])
  items OrderItem[]

  @@index([userId])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id         Int     @id @default(autoincrement())
  orderId    Int     @map("order_id")
  productId  Int     @map("product_id")
  model      String  @db.VarChar(80)
  qty        Int
  unitPrice  Decimal @map("unit_price") @db.Decimal(10, 4)
  lineTotal  Decimal @map("line_total") @db.Decimal(12, 2)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

model Favorite {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  productId Int      @map("product_id")
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("favorites")
}

model CompareList {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  productId Int      @map("product_id")
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("compare_list")
}

model Review {
  id          Int      @id @default(autoincrement())
  productId   Int      @map("product_id")
  userId      Int      @map("user_id")
  rating      Int      @db.UnsignedTinyInt
  title       String?  @db.VarChar(120)
  content     String?  @db.Text
  pros        String?  @db.VarChar(500)
  cons        String?  @db.VarChar(500)
  isVerified  Boolean  @default(false) @map("is_verified")
  status      String   @default("pending") @db.VarChar(20)
  createdAt   DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@index([productId])
  @@map("reviews")
}

model Newsletter {
  id              Int       @id @default(autoincrement())
  email           String    @unique @db.VarChar(120)
  language        Language  @default(en)
  isActive        Boolean   @default(true) @map("is_active")
  unsubscribedAt  DateTime? @map("unsubscribed_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@map("newsletter")
}

model AuditLog {
  id         BigInt   @id @default(autoincrement())
  userId     Int?     @map("user_id")
  action     String   @db.VarChar(60)
  entityType String?  @map("entity_type") @db.VarChar(40)
  entityId   Int?     @map("entity_id")
  changes    Json?
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  userAgent  String?  @map("user_agent") @db.VarChar(500)
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model Setting {
  k         String   @id @db.VarChar(60)
  v         String?  @db.Text
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}
