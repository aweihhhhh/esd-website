# ====== 服务器 ======
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# ====== 数据库 (MySQL 8.0) ======
DATABASE_URL="mysql://root:123456@localhost:3306/esd_website"

# ====== Redis (缓存 + 限流) ======
REDIS_URL=redis://localhost:6379

# ====== JWT ======
JWT_SECRET=change-this-to-a-very-long-random-string-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ====== 邮件 (SMTP) ======
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="ESD Diode Wholesale <noreply@esd-diode.com>"

# ====== 文件上传 ======
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# ====== 前端 URL (邮件链接用) ======
FRONTEND_URL=http://localhost:5173

# ====== 公司信息 ======
COMPANY_NAME="ESD Diode Wholesale"
COMPANY_EMAIL=sales@esd-diode.com
COMPANY_PHONE="+86 138 0000 0000"
COMPANY_WHATSAPP=8613800000000
